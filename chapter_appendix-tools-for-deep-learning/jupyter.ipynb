        "t = int(input())\n",
        "for _ in range(t):\n",
        "    a, b, m = map(int, input().split())\n",
        "    out = 0\n",
        "\n",
        "    if m < a and m < b:\n",
        "      out = 2\n",
        "      continue\n",
        "    for m\n",
        "\n",
        "    print(out)\n"
